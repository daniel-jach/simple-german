@Article{Dubova.2016,
  author    = {Agnese Dubova and Egita Proveja},
  title     = {Datengeleitetes Lernen im studienbegleitenden Deutschunterricht am Beispiel des KoGloss-Ansatzes},
  journal   = {Zeitschrift für Interkulturellen Fremdsprachenunterricht},
  year      = {2016},
  volume    = {21},
  number    = {1},
  pages     = {99--109},
  abstract  = {Der vorliegende Aufsatz stellt den sprachdidaktischen Ansatz KoGloss vor und beschreibt die Möglichkeiten seines Einsatzes im studienbegleitenden Deutschunterricht. Als eine der Formen des datengeleiteten Lernens ermöglicht der KoGloss-Ansatz eine forschungsorientierte und lernerzentrierte Herangehensweise, die insbesondere im akademischen Sprachunterricht gefragt ist. Eine korpusbasierte Erschließung von (Fach-)Wörtern und komplexen sprachlichen Mustern, das learning by doing, die Kooperation und Kollaboration zwischen den Lernenden und Lehrenden dienen als Schlüsselwörter zur Beschreibung der mit KoGloss angestrebten Lehr- und Lernform im studienbegleitenden Unterricht des Deutschen als Fremdsprache (bzw. Fachsprache). The paper deals with the didactic approach of KoGloss in language acquisition and describes the possibilities of its use in acquisition of German language as study-accompanying course. As one of the data-driven approaches types the KoGloss approach ensures research-driven and learner-centered learning, which is particularly important in language instruction in higher education. The keywords given by KoGloss for the learning and teaching method of acquisition of the “accompanying” study subject, i.e. the German language as foreign language (namely as language for special purposes – LSP) are as follows: defining corpus-based special application of words and complex language patterns, learning by doing, cooperation and collaboration between the teaching staff and students.
Example of teaching approach of data-driven / corpus-based learning of German as a foreign language. In the KoGloss approach, learners collect texts and then search corpus for constructions (recurring form-meaning patterns with pragmatic and discursive properties) and describe form, meaning and usage in glosses, similar to self-made dictionaries.},
  langid    = {ngerman},
  owner     = {daniel},
  timestamp = {2020.08.25},
}

@InCollection{Gibson.2000,
  author    = {Gibson, Edward},
  title     = {The Dependency Locality Theory: {A} Distance-Based Theory of Linguistic Complexity},
  booktitle = {Image, Language, Brain},
  publisher = {MIT Press},
  year      = {2000},
  editor    = {Alec Marantz and Yasushi Miyashita and Wayne O'Neil},
  pages     = {95--126},
  address   = {Cambridge, MA},
  abstract  = {Following up on his earlier proposal of the Sentence Prediction Locality Theory (\cite{Gibson.1998}), Gibson (\cite*{Gibson.2000}) proposed a revised version primarily based on linear distance and locality baptized Dependency Locality Theory (DLT) of sentence processing. 

As already pointed out in the earlier paper, an important part of a theory of sentence comprehension is a theory of sentence parsing, that is, a theory of how sentence structure is assembled as words come in in a linear order and one at a time. According to the revised version of the theory, sentence parsing involves two processing compontents consuming computational resources. First, performing structural integrations, that is, connecting a word into the structure for the input thus far. Second, keeping the structure in memory, which includes keeping track of incomplete dependencies. Key to this interaction between parsing mechanisms and computational resources is the idea of locality. According to Gibson (\cite[95f.]{Gibson.2000}), ``the cost of integrating two elements (such as a head and a dependent, or a pronominal referent to its antecedent) depends on the distance between the two''. 

Gibson discussed some complexity phenomena with respect to computational complexity and rules out possible other explanations. 

For example, comparing singly nested (1) and doubly nested (2) structures, one intuitively notices the higher complexity of (2). 

(1) The reporter who the senator attacked disliked the editor. 
(2) The reporter who the senator who John met attacked disliked the editor. 
(3) John met the senator who attacked the reporter who disliked the editor.

Gibson points out that the intuitive increase in complexity from (1) to (2) is not due to lexical material or plausibility factors. Moreover, no ambiguity is involved. Instead, he argues that ``[t]he difficulty associated with processing nested structures is probably caused by the quantity of resources they require during their processing'' (\cite[96]{Gibson.2000}). This becomes evident when (2) is compared to (3), which includes lexical material to and is as plausible as (2), yet, which is intuitively easier to process. Previous theory of nesting complexity may account for this phenomena by reference to the number of incomplete dependencies, however, they fail to predict facilitating effects of pronouns as the subject of the most embedded relative clause, (4). 

(4) A book that some Italian that I have never heard of wrote will be published soon by MIT Press.

Note that even though (4) and (3) are structurally similar (same number of incomplete dependencies while processing), (4) is relatively easy to process. According to Gibson, this results from the accessibility of the discourse referent. While proper names and definite noun phrases introduce new discourse referents, indexical pronouns refer to referents already present in the discourse which is why they are easily accessible. 

The revised processing theory of computational complexity, DLT, accounts for these phenomena. The DLT has two key insights. First, ``]r]essources are required for \textit{two} aspects of language comprehension: (1) \textit{storage} of the structure built thus far (as in earlier theories) and (2) \textit{integration} of the current word into the structure built thus far.'' Second, ``[t]he structural integration complexity depends on the \textit{distance} or \textit{locality} between the two elements being integrated'' (\cite[102]{Gibson.2000}). 

A newly introduced XP needs to be integrated into the discourse and syntactic structure built thus far. The process of integration depends on the distance between the heads of the two projections being integrated together. When the second head is processed and needs to be integrated with a previous syntactic category headed by the first head, aspects of the first head need to be retrieved from memory. Because of the limited quantity of resources and activation in the processor, the activation of the first head will decay as intervening words are processed and integrated into the structure for the input, which makes retrieval of the first head more demanding. Gibson defines structural integration cost as follow: ``The structural integration cost associated with the syntactic structure for a newly input head \textit{h\textsubscript{2}} to the projection of a head \textit{h\textsubscript{1}} that is part of the current structure for the input is dependent on the complexity of the computations that took place between \textit{h\textsubscript{1}} and \textit{h\textsubscript{2}}. For simplicity, it is assumed that 1 E[nergy] U[nit] is consumed for each new discourse referent in the intervening region.'' (\cite[105]{Gibson.2000}) 

This way, the DLT accounts for nesting complexity effects as well as effects of pronouns: ``Because the referents for first- and second-person pronouns are already present in the current discourse, integrating across them consumes fewer resources than integrating across new discourse referents'' (\cite[107]{Gibson.2000}). (Apparently, Gibson assumes that referents of first- and second-person pronouns do not have a mental representation which needs to be kept in memory. Otherwise, re-activation of speaker and addressee referents would consume computational resources and, therefore, older memories should decay.) 

The DLT also accounts for the subject-object asymmetry in processing English relative clauses. For one thing, integration cost at the relative clause verb is higher in object- than in subject-extracted relative clauses depending on the number of XP elements intervening between the position of the gap within the relative clause and the clause-initial relative pronoun filler (page 109f.). (Gibson conducted a reading time study and explains how to normalize measured reading times for length of words using linear regression equation across all sentences in the experiment in order to arrive at residual reading times (reading time of a typical word) as a basis for assessing locality-based integration effects on reading time). For another thing, memory cost at the relative pronoun is higher in object- than in subject-extracted relative clauses because more syntactic heads need to be predicted to make a grammatical sentence (page 114). 

Storage and integration cost interrelate in sentence processing. Gibson assumes that integrations and storage access the same pool of resources, that there is a fixed (limited) capacity of resources in the pool and that each predicted head takes up a fixed quantity of resources. As a result, the more resources that are required in storage, the slower integration occurs. 

Gibson applies the DLT to ambiguity resolution, as discussed in Trueswell et al. (1994) and MacDonal et al. (1994). While Trueswell and MacDonald point to the role of lexical frequency and plausibility in ambiguity resolution, which they considered independent of computation complexity, Gibson objects that the examples used to investigate disambiguating factors were indecisive with respect to computational complexity. In particular, while Trueswell et al. (1994) argue that readers of (1) favor a reduced relative clause reading over a main clause reading because of lexical and plausibility factors, Gibson demonstrates that the two possible readings do not differ in computation complexity. 

(1) The evidence examined by the lawyer turned out to be unreliable. 
(2) The witness who the evidence examined by the lawyer implicated seemed to be very nervous. 

Instead, he emphasizes that ``it is necessary to compare the resolution of an ambiguity with a small resource complexity difference with the resolution of ambiguities with larger resource complexity differences, while controlling for lexical frequency and plausibility'' (\cite[117]{Gibson.2000}). In (2), plausibility favors a RR reading over an MV reading of `examined', whereas computational complexity favors a (completely implausible) MV reading over a RR reading. If the DLT storage cost is being used in ambiguity resolution online, readers will have more difficulty following the RR reading of the verb `examined' in (2) than in (1). In a more elaborated experimental design, reading times of ambiguous sentences with large storage cost difference (2) and with low storage cost difference (1) were compared to unambiguous control sentences. As expected by the DLT, reading times were faster for small storage cost conditions. Moreover, disambiguation took longer in conditions with large storage cost difference. Thus suggests that readers initially follow the MV reading because of its lower complexity and in spite of its implausibility. Readers use plausibility information for disambiguation when computational complexity does not favor any interpretation.},
  owner     = {daniel},
  timestamp = {2020.08.25},
}

