@Article{Seitz.2014,
  author    = {Simone Seitz},
  title     = {Leichte Sprache? Keine einfache Sache},
  journal   = {Aus Politik und Zeitgeschichte},
  year      = {2014},
  volume    = {64},
  number    = {9--11},
  pages     = {3--6},
  abstract  = {Seitz führt die prinzipielle Idee ein: Leichte Sprache oder Einfache Sprache war ursprünglich vor allem als Mittel für Menschen mit Lernschwierigkeiten gedacht, ihre Rechte besser kennenzulernen. Die Zielgruppe umfasst aber inzwischen neben Menschen mit Lernschwierigkeiten z.B. mehrsprachig lebende Menschen. Themenfelder sind aber oft von besonderer Relevanz für Menschen mit Lernschwierigkeiten. Im Kontext Mehrsprachigkeit ergeben sich außerdem noch andere sprachliche Anforderungen. Leichte Sprache muss verständlich, darf aber nicht diskriminierend oder inhaltlich verfälschend sein: "Es geht darum, Zugänge zu komplexen Sachzusammenhängen zu ermöglichen, die Zusammenhänge aber nicht unangemessen zu vereinfachen, sondern auf das Wesentliche hin zu konzentrieren, gewissermaßen eine Essenz des Textes zu erstellen." (5) Adressaten und Verwendungsmöglichkeiten von leichter Sprache sind "mittlerweile breit und heterogen" (5). Leichte Sprache geht über das Sprachliche im engeren Sinne hinaus und bezieht auch kulturell gebundenes implizites Wissen mit ein, etwa über Funktionsregeln und Verfahrne in Bildungsinstitutionen.},
  langid    = {ngerman},
  owner     = {daniel},
  timestamp = {2020.08.23},
}

@Article{Kellermann.2014,
  author    = {Gudrun Kellermann},
  title     = {Leichte und Einfache Sprache -- Versuch einer Definition},
  journal   = {Aus Politik und Zeitgeschichte},
  year      = {2014},
  volume    = {64},
  number    = {9--11},
  pages     = {7--10},
  abstract  = {Die Begriffe "Leichte Sprache" und "Einfache Sprache" werden oft synonym verwendet. Im engeren Sinne wird unter leichter Sprache Sprache mit dem Ziel verstanden, "Menschen mit Leseschwierigkeiten die Teilhabe an Gesellschaft und Politik zu ermöglichen" (7). Sie folgt bestimmten lexikogrammatischen und typo- und orthographischen grafischen Regeln. Dazu gehören in sprachlicher Hinsicht vor allem die Vermeidung von Nebensätzen, die Verwendung von bekannten Wörtern und die Erklärung schwieriger Wörter. Regelwerk vom Netzwerk Leichte Sprache. Für einfache Sprache gibt es kein bestimmtes Regelwerk. Sie ist in der Regel komplexer als Leichte Sprache. Im Alltag gebräuchliche Wörter werden verwendet, Fremdwörter werden vermieden oder erklärt. Texte in einfacher Sprache haben einen größeren Benutzerkreis als Leichte Sprache. Die Webseite nachrichtenleicht.de wird in einfacher Sprache verfasst. Der Artikel geht weiter auf die Verwendung Leichter Sprache in Europa und ihren Stellenwert in der Gegenwart ein.},
  owner     = {daniel},
  timestamp = {2020.08.23},
}

@Article{Stefanowitsch.2014,
  author    = {Anatol Stefanowitsch},
  title     = {Leichte Sprache, komplexe Wirklichkeit},
  journal   = {Aus Politik und Zeitgeschichte},
  year      = {2014},
  volume    = {64},
  number    = {9--11},
  pages     = {11--18},
  abstract  = {Stefanowitsch geht auf die heterogenen Zielgruppen leichter Sprache ein und unterscheidet Gruppen mit unveränderlichen Schwierigkeiten (z.B. wegen kognitiver oder anderer kröperlicher Einschränkungen) einerseits und Gruppen, die dabei sind, Deutsch zu erwerben (z.B. Nicht-Muttersprachler). Der zentrale Punkt von Stefanowitsch' Beitrag ist der Trafe-Off zwischen sprachlicher und inhaltlicher Komplexität: Sprachliche Komplexität der Standard- und Schriftsprache sei nicht nur funktionslose Ornamentik, sondern ergeben sich aus den erweiterten Ansprüchen an Standard- und Schriftsprache in einer komplexen Gesellschaft (etwa die situationsentbundene Kommunikation, die Kommunikation über Fachinhalte usw.). Er bezieht Leichte Sprache dann auf den Begriff "restringierter Code" (vs. elaborierter Code) nach Bernstein und macht auf soziale Funktionen und kognitive Effekte unterschiedlicher Sprachvarietäten aufmerksam. Die Einschränkung sprachlicher Komplexität hat in dieser Sicht nicht nur inhaltliche, sondern auch soziale und möglicherweise kognitive unerwünschte Nebenwirkungen. Insgesamt mahnt Stefanowitsch also zur Vorsicht bei der Einschränkung sprachlicher Komplexität.},
  langid    = {ngerman},
  owner     = {daniel},
  timestamp = {2020.08.23},
}

@Article{Nickel.2014,
  author    = {Sven Nickel},
  title     = {Funktionaler Analphabetismus -- Hintergründe eines aktuellen gesellschaftlichen Phänomens},
  journal   = {Aus Politik und Zeitgeschichte},
  year      = {2014},
  volume    = {64},
  number    = {9--11},
  pages     = {26--32},
  abstract  = {Nickel befasst sich in seinem Beitrag mit der Entstehung und Ausbreitung von Analphabetismus in individuellen Bildungsbiografien und gesellschaftlichen Kontexten und referiert hierfür die Ergebnisse verschiedener großer Bildungsstudien. Funktionaler Analphabetismus (also die Unfähigkeit, mit Schrift auf eine hinreichend kompetente Weise umzugehen) betrifft einen unerwartet großen Teil der erwachsenen Bevölkerung: 4,4 Prozent können nur Wörter, aber keine Sätze lesen; weitere 10 Prozent können kurze Sätze, aber keine Texte lesen (27). Weitere 25,9 Prozent haben Schwierigkeiten beim Lesen und Rechtschreiben. Danach stellt "Leichte Sprache für über 40 Prozent (über 20 Millionen Menschen) der gesamten erwachsenen Bevölkerung einen angemessene Form der Schriftlichkeit dar" (28). Mehrsprachige Menschen sind in der 14,5-Gruppe der funktionalen Analphabeten im Vergleich zu Gesamtbevölkerung zwar überrepräsentiert, über die Hälfte der Betroffenen (58 Prozent) sind aber Muttersprachler. Auf Seite 28 fasst Nickel in einem Kasten Regeln für leichte Sprache zusammen. Abbildung 2 fasst die typische Bildungsbiografische Entstehung von Analphabetismus auf der Grundlage von Untersuchungen von Teilnehmenden in Alphabetisierungskursen zusammen (30).},
  langid    = {ngerman},
  owner     = {daniel},
  timestamp = {2020.08.23},
}

