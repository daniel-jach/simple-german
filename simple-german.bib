@Article{Grotlueschen.2019,
  author    = {Grotlüschen, Anke and Buddeberg, Klaus and Dutz, Gregor and Heilmann, Lisanne and Stammer, Christopher},
  title     = {LEO 2018 – Leben mit geringer Literalität},
  year      = {2019},
  abstract  = {Die zweite Leveo-One Studie 2018 (LEO 2018) erfasst die Lese- und Schreibkompetenzen der Deutsch sprechenden erwachsenen Bevölkerung (18-64 Jahe) und berichtet dies differenziert für die unteren Kompetenzstufen des Lesens und Schreibens - die so genannten Alpha-Levels. Die Studie schreibt die Ergebnisse der LEO - Level-One Studie aus dem Jahr 2010 fort. Die Daten zeigen, dass 2010 rund 12% der Bevölkerung als gering literalisiert zu gelten hat (LEO 2010: 14,5%). Hochgerechnet sinkt der Wert von 7,5 Millionen auf 6,2 Millionen Erwachsene im Alter von 18-64 Jahren.},
