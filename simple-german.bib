@InProceedings{Tschirner.2019,
  author    = {Tschirner, Erwin},
  title     = {Der rezeptive Wortschatzbedarf im Deutschen als Fremdsprache},
  booktitle = {Akten der XVI. Internationalen Deutschlehrertagung (IDT)},
  year      = {2019},
  editor    = {T. Studer and I. Thonhauser and E. Peyer},
  pages     = {98--111},
  publisher = {Erich Schmidt},
  abstract  = {Tschirner unterscheidet zwischen pragmatisch orientierten Wortschätzen (z.B. dem GER-Wortschatz) und häufigkeitsbasierten Wortschätzen. Pragmatisch orientierte Wortschätze sind in DaF/DaZ weit verbreitet und eignen sich vor allem für den Erwerb mündlicher, alltagssprachlicher Kompetenz (obwohl hierbei Lerner-spezifische Variation besonders ins Gewicht fällt). Häufigkeitsbasierte Wortlisten bilden hingegen besser rezeptiven, schriftlichen, bildungssprachlichen Wortschatz ab. Tschirner zeigt empirisch, der Erwerb wievieler der häufigsten Wörter eine hohe "Textdeckung" und damit Textverstehen (Wortschatzumfang und Textverstehen korrelieren) bedingt. Die pragmatisch orientierten Wortlisten enthalten die häufigsten Wörter nur zum Teil, ihr Erwerb trägt daher nicht vollumfänglich zum Textverstehen bei. Pragmatische Wortlisten werden außerdem von "Experten" mehr oder minder intuitiv erstellt, was notgedrungen zu subjektiver Auswahl führt. Textverstehen ist wichtig für den Erwerb von konnotativen Bedeutungen und grammatischem Verhalten (Kollokationen) von Wörtern. Quantitative Untersuchungen der GER-Wortlisten haben ergeben, dass das Niveau A1 unter 1000 der häufigsten deutschen Wörter enthält, A2 unter 2000, B1 unter 3000, B2 unter 4000 und C1 weit mehr als 5000 (Seite 101). Tschirner schlussfolgert, dass der Nutzen verschiedener Wortlisten von Domäne, Modalität und Zielgruppe abhängt: "Erwachsene Lernende, die im Gastland den Alltag meistern müssen, kann durchaus ein pragmatischer Ansatz von Nutzen sein, während für bildungssprachliche Kontexte ein korpuslinguistischer und frequenzbasierter Ansatz sicher zielführender wäre." (Seite 104). Tschirner macht noch Vorschläge für den Erwerb von Wörtern und ihrer unterschiedlichen Bedeutungsanteile und betont die Wichtigkeit von Lesen und verschiedener Text-basierter Übungen für den Erwerb nicht-denotativer und grammatischer Worteigenschaften. Er kritisiert, dass entgegen anderer Erkenntnisse der Forschung bis dato kein DaF/DaZ-Vokabeltrainer existiere, der dem gerecht werde.},
  langid    = {ngerman},
  owner     = {daniel},
  timestamp = {2020.08.24},
}

@InProceedings{Tschirner.2006,
  author    = {Tschirner, Erwin},
  title     = {H{\"a}ufigkeitsverteilungen im Deutschen und ihr Einfluss auf den Erwerb des Deutschen als Fremdsprache},
  booktitle = {Atti del XII Congresso Internationale di Lessicografia},
  year      = {2006},
  editor    = {Corina, Elisa and Marello, Carla and Onesti, Christina},
  pages     = {1277--1288},
  address   = {Alessandria, Italien},
  publisher = {Edizioni dell’Orso},
  abstract  = {Tschirner führt in die haufigkeitsbasierte Fremdsprachendidaktik ein und kritisiert, dass die Wortlisten von Häufigkeitswörterbüchern und Grund- und Aufbauwortschätzen des Deutschen auf veralteten (teils über einhundert Jahre alten) Korpora basieren. Er beschreibt das neue Herder/BYU-Korpus, auf dem das Häufigkeitswörterbuch Jones/Tschirner (2006) basiert. Vergleiche von Jones/Tschirner (2006) und verschiedenen Grund- und Aufbauwortschätzen (Langenscheidt, Profile Deutsch) zeigen große Unterschiede: Die Wortschätze enthalten zu einem großen Teil die häufigsten Wörter des Deutschen nicht und stattdessen seltener Wörter. Eine Untersuchung zum Zusammenhang von Worthäufigkeit und Textdeckung zeigt für verschiedene Textsorten, dass Textdeckung und damit Textverstehen vor allem vom Erwerb der häufigsten Wörter abhängen. Dass die Gebrauchshäufigkeit noch andere für die Fremdsprachendidaktik relevante Aspekte enthält, zeigt Tschirner am Beispiel von Wechselpräpositionen. Diese kommen in seinem Korpus in häufigen Verbindungen (chunks) vor, z.B. in der Stadt, auf der Straße. Bedeutung (lokal, nicht-lokal) und Kasusmarkierung (Dativ, Akkusativ) sind dabei äußerst ungleich verteilt. Das legt nahe, dass die Wechselpräpositionen und ihre Kasus als Teile routinisierter Chunks mit fixen Bedeutungen gebraucht und erlernt werden. Viele solcher Chunks zählen sogar zu den häufigsten Wörtern.},
  langid    = {ngerman},
  owner     = {daniel},
  timestamp = {2020.08.24},
}

