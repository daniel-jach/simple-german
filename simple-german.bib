@Book{Ellis.2016,
  title     = {Usage-based Approaches to Language Acquisition and Processing: {C}ognitive and Corpus Investigations of Construction Grammar},
  publisher = {Wiley-Blackwell},
  year      = {2016},
  author    = {Ellis, Nick C. and Römer, U. and O’Donnell, M. B.},
  address   = {Malden, MA},
  abstract  = {Chapter 1
In this chapter, Ellis et al. outline the assumptions of the construction grammar usage-based approach they adopt for the investigation of a particular type of verb argument constructions (VACs): verb locative constructions (VLCs). They consider language and cognition as "mutually inextricable" (23) and propose that language learning involves determining structure from usage by means of cognitive processes not specific to the learning of language but involved in the learning of all other aspects of the world. The question overarching and underlying the usage-based research paradigm is: "Do generic learning mechanisms---operating in and across the human systems for perception, motor-action, and cognition as they are exposed to language data as part of a communicatively rich human social environment by an organism eager to exploit the functionality of language---suffice to drive the emergence of complex language representations?" (24) A conglomerat of neighboring disciplines and fields, empirical and theoretical approaches contribute to answering this question, for example, corpus linguistics, cognitive psychology, cognitive linguistics, construction grammar, functional linguistics, statistical learning theory, child language acquisition, natural language processing, emergentism and complex system theory, dynamic systems theory, sociolinguistics, and social learning theory. In the following, Ellis et al. outline some basic assumptions of construction grammar usage-based research in more detailed but concise subchapters under the headings Construction Grammar, Basic-Level Constructions and Embodiment, Formulaic Language and Corpus Approaches, Inseparability of Lexis, Grammar, and Semantics, Verb-Argument Constructions, Exemplar-based Abstractions, Construction Processing is Probabilistic, Construction Processing is Rational, VAC Structural Priming, and VAC Priming in Dialogic Alignment. Against this background, they set out "to determine if the shape of usage [of VLCs, DJ] follows the characteristics that encourage category learning, and thus might make language robustly learnable despite learners' idiosyncratic samples of exposure" (43). Foreshadowing their results, they conclude that "Our research shows how known mechanisms of associative and cognitive learning, when exposed to naturalistic usage, drive language acquisition and organize language representations for optimal access" (44).

Chapter 2 Determinants of Construction Learning
In this chapter, Ellis et al. outline a range of determinants of usage-based learning and consider them in more detail in turn: frequency of experience, chunking and sequence learning, meaning (significance in comprehension of utterance, prototypicality, generality, redundancy, surprise,...), contingency and mapping of form and meaning, form (salience, length, constituents, regularity), and learner attention (automaticity, transfer, overshadowing, blocking). Frequency effects. As is well-known, "Learning, memory and perception are all affected by frequency, recency, and context of usage" (45). There is abundant evidence for effects of frequency on the memorization and processing of items and sequences (chunks on all levels of language organization). Each usage event implicitly primes the category we recognize in the event and thereby entrenches the category (in other words, increases the resting level of activity). Many additional factors qualify this picture. To mention just one, the relationship between frequency of usage and change of activation threshold (entrenchment) is not linear but follows a curvlinear 'power law of practice' "whereby the effects of practice are greatest at early stages of learning, but eventually reach asymptote" (47). Linguistic memory is organized in frequent sequences, chunks, on all levels of language. There is abundant evidence for effects of chunks (measured by corpus linguistic metrics like mutual information and transitional probability) on psycholinguistic measures like recall rate, grammaticality judgement, reading time, response time, and eye movement. This demonstrates that learners acquire statistical knowledge about the usage of the language they learn, which doesn't imply that counting is conscious; instead counting is implicit and unconscious. Ellis summarizes the subchapters as follows: "This research demonstrates that associative learning from usage results in chunking at all levels of language. Language knowledge involves statistical knowledge, so humans learn more easily and process more fluently high-frequency forms and regular patterns that are exemplified by many types and that have few competitors. Usage-based perspectives of acquisition thus hold that language learning is the implicit associative learning of representations that reflect probabilities of occurrence of form-function mappings. Frequency is a key determinant of acquisition because rules of language, at all levels of analysis, from phonology, through syntax, to discourse, are structural regularities that emerge from learners' lifetime unconscious analysis of the distributional characteristics of the language input." (56f.) Last, Ellis et al. introduce Zipfian Frequency Distribution observable on various levels of language (and in non-linguistic domains like strengths of earthquakes, hits of a webpage, etc.). Note that not only linguistic forms but also the things they refer to exhibit Zipfian or near-Zipfian distributions. Zipfian distribution is suspected to be fundamental to the structure and robustness of Complex Adaptive Systems. Accordingly, usage-based linguistics argue "that it is the coming together of Zipfian-like distributions across linguistic form and linguistic function that promotes robust language learning despite learners' idiosyncratic experience" (58f.). Following this, Ellis et al. address matters of categorization and meaning which is widely seen as based on prototypes or prototypical clusters of exemplars with which new stimuli are compared. From this follows that "Human categorization thus shows effects of both abstract categorical representations and of concrete exemplars" (60), more specifically, for exemplar learning, frequency effects, prototypicality effects, and in-crowd effects, and, for category learning, variability effects, and order of exposure effects (see for details, page 60). "These are the types of factors which determine the learnability of categories. If VACs and other linguistic constructions are learned as categories, then we should see these factors in construction learning" (60). They suggest to use semantic networks to analyze prototypicality, semantic cohesion, and polysemy. Moreover, as is well-known, raw frequency of a cue is often overridden by the reliability with which this cue indicates the outcome (e.g., wings and eyes equally frequent, but only wings reliably indicate the category BIRD). As research on contingency learning has demonstrated, "the more reliable the mapping between a cue and its outcome, the more readily it is learned" (63). Next, Ellis et al. consider salience and perception of linguistic forms. "Low salience cues tend to be less readily learned." (64) Last, they consider implicit and explicit learning. "Implicit learning is acquisition of knowledge about the underlying structure of a complex stimulus environment by a process which takes place naturally, simply and without conscious operations." (64) "Explicit learning is a more conscious operation where the individual makes and tests hypotheses in a search for structure." (64) Most of language learning and processing is implicit. This, however, does not mean that explicit learning is impossible. When language processing falters, explicit learning "allows us to consolidate new constructions as episodic 'fast-mapped' cross-modal associations" (65) then available as units of implicit learning in subsequent processing, and in second language learning, explicit learning counteracts L1 attentional biases. Still, "The bulk of language acquisition is implicit learning from usage. Most knowledge is tacit knowledge; most learning is implicit; the vast majority of our cognitive processing is unconscious. Implicit learning supplies a distributional analysis of the problem space: our language system implicitly figures out how likely a given construction is in particular contexts, how often they instantiate one sense or another, how these senses are in turn associated with different features of the context, and so on." (66) "The mechanism underlying such unconscious counting is to be found in the plasticity of synaptic connections rather than abacuses or registers, but it is counting nevertheless." (66) "Everything is connected, resonating to a lesser or greater degree, in the spreading activation of the cognitive unconscious, and linguistic categories emerge as attractor states in the reverberations of related exemplars in implicit memory." (66) To end, note that all these learning determinants don't operate in isolation "but they interact dynamically in every episode of usage" (68).

Chapter 3 VACs in Usage
In this chapter, Ellis et al. investigate usage patterns of VACs based on samples from the BNC. Based on patterns described in COBUILD Grammar Patterns 1: Verbs (Francis et al., 1996), they build search graphs and extracted samples of VLCs from the BNC. They determine the type and token frequencies of verbs in the constructions, their contingency of association with the constructions, and the semantic associations of the verbs to see whether they form coherent meaning groups. As a measure of association, they use delta P which is defined as "the probability of the outcome given the cue (P(O|C)) minus the probability of the outcome in the abscence of the cue (P(O|not-C)). For semantic analysis, they computed semantic networks based on WordNet for a selection of verbs. From WordNet, a similarity measure for each verb pair is extracted and then links are established between sufficiently similar verbs. The resulting network is grouped into "communities" (i.e. clusters). Based on this, measures of prototypicality, semantic coherence, and polysemy are computed. The results show that the type token frequency distributions of the verbs is Zipfian or near-Zipfian. "Zipf's law, like other power-law distributions, is most easily tested by plotting on doubly logarithmic axes, where the relationship between log (rank order) and log (frequency) should be linear with the regression line, explaining a large part of the variance (R squared) of the distribution" (89). Because Zipf's law applies across language phenomena, they measure the correlation between the rank verb frequencies in the construction and in language as a whole using chi-square goodness-of-fit test and Kendall's tau. The results indicate that rank order in construction and in language as a whole don't correlate, suggesting that "these Zipfian distributions of VACs are special: They are not simply random samples from language as a whole. VACs select particular verbs" (91). Based on delta P values, they determine which verbs most reliably cue a construction and vice versa. The semantic analysis produces clusters of similar verbs forming protoypes. In sum, "Our analyses show that these constructions are (1) Zipfian in their verb type-token constituency in usage, (2) selective in their verb form occupancy, and (3) coherent in their semantics, with a network structure involving prototypical nodes of high betweenness centrality. Psychological theory relating to statistical learning of categories suggests that these are all factors that promote learning" (96).

Chapter 4 VACs in L1 Knowledge and Processing
In this chapter, Ellis et al. report the results of two fill-in-the-blank experiments in which they asked native speakers (1) to complete phrase fragments with a plausible verb and (2) to list all plausible verbs which come to their minds in one minute. They correlated the frequency of the elicited verbs with the frequency, contingency, and semantic prototypicality of the verbs determined in the corpus study in chapter 3, and then conducted regression analyses to assess the explanatory power of each factor. As expected, they found correlations between frequency of elicited verbs and all corpus-derived measures. Results of regressions analyses indicated that delta P (contingency) was the major predictor of frequency of elicited verbs, followed by verb-construction joint frequency, followed by prototypicality. The effects of frequency and contingency on processing/production are discussed in terms of Hebbian learning and psychology of learning. The effects of semantic prototypicality are interpreted in terms of a spreading activation network model of semantic memory. Ellis et al. concede that their results are inconclusive with respect to the question whether language users have acquired stable mental representations (Goldberg 1995, 2006) or rather dynamically activate knowledge to build ad hoc categories (Barsalou 2010). Be that as it may, the results indicate that "language users have acquired statistical knowledge of the frequencies and contingencies across syntagmatic patterns of linguistic form, verb-frame type-token frequency distributions, and paradigmatic associations with semantic networks" (118). Learners have tallied these frequencies from usage, needless to say, not consciously, but implicitly or incidentally in the course of communication.

Chapter 5 VACs in L2 Knowledge and Processing
In this chapter, the experiments from chapter 4 are repeated with advanced German, Czech, and Spanish learners of English. Ellis et al. analyzed whether the nonnative responses were predicted by the corpus-based measures computed in chapter 3 based on the BNC and compared the nonnative to the native responses from chapter 4 by means of series of linear regression analyses. Moreover, note that German and Czech, like English, tend to use particles to express direction of motion and manner of motion in the verb ("run away", "come in") [satellite-framed languages], whereas Spanish tends to encode direction of motion in the verb ("entrar") [verb-framed language]. Ellis et al. therefore predicted that German and Czech learners would produce more specific manner verbs and Spanish learners more general verbs like "go", "come", and "move" and less specific manner verbs. Moreover, they expected collocational transfer from the learners' L1s (125.f). The results indicate that second language acquisition of VACs is based on usage, i.e. affected by factors like frequency, contingency, and prototypicality. Moreover, comparison to NS responses revealed L1-specific patterns indicating that learning from usage is biased by first language as predicted. In general, German and Czech responses were more similar to NS responses than Spanish ones. "To the extent that the constructions in L2 are similar to those of the L1, L1 constructions can serve as the basis for the L2 constructions, but because even similar constructions across languages differ in detail, the acquisition of the L2 pattern in all its detail is hindered by the L1 pattern" (149). All three learner groups relied more on general, highly frequent verbs than the NS. Moreover, for certain learner groups, semantic associations with a VAC were different from NSs. For example, as expected, German and Czech learners produced more specific manner verbs and Spanish learners more general verbs. Echoing earlier findings, Ellis et al. conclude that "a learner's L1 and the L1-tuned expectations that come with it bias her/his system and, depending on how typologically similar or different the L1 and L2 are, make her/him more or less open to internalizing structures in the L2" (150). Moreover, collocational transfer was evident in the data. For example, German learners associate verbs like "be", "fight", "hit", "argue", "vote", "rebel" "speak", etc. with fragments including the preposition "against", whereas NS participants associated "lean", "fall", and "go", arguably due to collocational transfer: most significant left-hand neighbours of German "gegen" are, e.g., "kämpfen", "protestieren", "votieren", "stimmen", whereas "drücken" and "fallen" tend to be used without or with a different preposition (e.g., "drücken auf", "fallen in/auf/von"). In sum, Ellis et al. found that "L2 constructions reflect usage of both L2 and L1" (151).

Chapter 6 Online Processing of VACs
In chapter 4, usage effects on processing of VACs were demonstrated in free association tasks, however, the authors submit that the effects might reflect conscious processing and the use of ad hoc categories rather than automatic processing and implicit knowledge. Therefore, in the current chapter, experimental tasks from research on online lexical access and processing were adapted and applied to construction access and processing. Five experiments were designed to measure the effects of verb frequency, verb frequency in the VAC, VAC-verb contingency (delta p), and verb prototypicality in the VAC upon perceptual recognition, naming, successive lexical decision, interposed lexical decision, and meaning judgement of VACs. For these online tasks, the VACs extracted from corpora were reduced to verb-preposition collocations. Details aside, results indicated that all usage measures had an effect on the online access and processing of VACs, even though not all processing measures were equally affected by all usage measures. The authors conclude that this suggests that "the constructicon has detailed statistical knowledge of the bindings of verbs and VACs, and this knowledge guides the wide range of language processing for recognition, comprehension, and production" (183). Verb frequency and verb frequency in the VAC came out as significant predictors in all tasks. Recognition and meaning decision was additiionally affected by verb-VAC contingency, whereas both successive and interposed lexical decision were influenced additionally by semantic prototypicality. The authors argue that these differences are due to differences between the speading activation of unconscious meaning representation (in lexical decision) and the election of a unitary interpretation in conscious comprehension (in meaning decision). All in all, the results compare well with results of research on lexical access and processing and thus suggest similar a unified conception of lexemes and constructions. The authors conclude that the "results encourage the conception of a unified constructicon where words and VACs alike are symbolic representations, acquired from usage, statistics and all, with their subsequent processing tuned probabilistically to usage experience" (184). With respect to string access and processing, the following seems to relate closely to my work on string frequency in preposition placement and therefore is worth mentioning in more detail. In the recognition task, the recognition threshold decreased with verb frequency and, more importantly, with the conditional frequency of the verb in the VAC. The authors argue that this indicates that "Language users preferentially process more probable multiword constructions" and that "language users are sensitive to syntagmatic associations (i.e., the collocation of verbs and prepositions)" (164). Later, they add that this is in line with the widely accepted assumption of cognitive models of lexical recognition that overall word frequency and local sequential context interact insofar as relevant contextual information facilitates word recognition (176). Similarly, in the naming task, the VOT of naming the preposition following a verb decreased with conditional frequency of the verb in the VAC. Apparently, "Verbs that appear more often in a VAC in usage prime the retrieval of the preposition name" (178). Moreover, in the successive lexical decision task, reaction times decrease with increasing conditional frequency. Conditional frequency is not the only factor determining dependent measures in the first three experiments, however, effects of conditional frequency suggest that processing was affected by the usage-based association strength between sequential elements. They relate these findings of all three experiments to earlier research which demonstrates "that language users have implicit knowledge of sequences of language" (179) (Ellis 2012 on phrasal teddy bears). In the interposed lexical decision task, a random adverb was inserted between verb and preposition, yet, effects of conditional frequency (and other usage factors) persisted. The authors conclude that "VAC associations are between the constituents themselves rather than between merely sequential elements" (173). This suggests that the relevant statistics "are not simple bigram collocations, but instead it is the probabilistic association between the verb and the VAC that is represented" (179).

Chapter 7 VACs in Parent and Child Language
The current chapter addresses the role of usage-based factors in child language acquisition. The authors analyzed child-directed speech and child speech available from the CHILDES database and divided child data in two age strata (1;6 to 3;0 and 3;0 to 6;0). Following earlier usage-based research (Goldberg, Tomasello, et al.), they hypothesized that (1) a construction's verb constituent types, ranked by frequency, would have a highly skewed, near-Zipfian distribution; (2) the most frequent verb types would be also closely associated with the construction; (3) the high-frequency, high-contingency verbs would be semantically central among the VAC verb constituents; (4) frequency, contingency, and semantic centrality in parents' use of a construction would correlate strongly with children's production; (5) frequency in parent speech will be a better predictor of younger children's use, with contingency emerging as a predictor in older children (189f.). All in all, all hypotheses were bourne out by the data, except hypothesis (5): Verb-VAC frequency was more strongly correlated in both age groups, surpassing both delta Pcw and betweeness centrality (i.e. prototypicality in meaning). Moreover, Pcw did no increase in predictive power with increasing age (209). The authors argue that in here-and-now, socially grounded contexts of child-parent interactions, the more frequent, generic forms work well enough, whereas the importance of contingency (delta Pcw) increases in (artificial/experimental) contexts of cue competition (for example, in free association tasks, chapter 4, or evaluating meaningfulness of VAC-verb associations, chapter 6) (212).

Chapter 8 VACs in L2 Acquisition
In the current chapter, the research design developed in Chapter 7 is applied to nonnative data from the longitudinal ESF project. Parts of this research were published in Ellis and Ferreira-Junior (2009a, 2009b) and Ellis and Larsen-Freeman (2009a). The data came from seven beginning to intermediate learners of English as a second language with L1 backgrounds Italian and Punjabi and their native interlocutors. The authors hypothesized that nonnative acquisition would be usage-based and therefore exhibit patterns similar to the ones observed in Chapter 7. In addition, while in Chapter 7 investigations focused on the verbs in the constructions only, here, corresponding hypotheses were formulated for the other slots in the construction (i.e. subject, object, and preposition slot). In this study (which was conducted earlier than the ones in the preceding chapters), semantic prototypicality was quantified using NS judgements rather than semantic network analyses. For analysis of contingency, they rely on delta P (word => construction, construction => word) and the collocational strength computed in collostructional analysis (-log10(Fisher-Yates p), Gries and Stefanowitsch). Results were strikingly similar to the native results in Chapter 7. In addition, results mostly confirmed the hypotheses concerning the other constructional slots, even though there was no single item that dominates each slot early in acquisition. The first-learned types in each VAC slot do tend to be more distinctively associated with that construction slot in the input, but to varying degrees: the verb slot of each construction attracts most distinct occupants, the subject slot least distinct (mainly high frequency pronouns), while preposition and object slots show some construction-specific selectivity. The authors conclude that "Each slot in each VAC thus makes a significant contribution to its identification and interpretation, and our general conclusion is that the acquisition of these linguistic constructions can be understood in terms of the cognitive science of concept formation. This follows the general associative principles of the induction of categories from the experience of the features of their exemplars. In natural language, the type--token frequency distributions of the occupants of each of these VAC slots, their prototypicality and generality of function in these roles, and their reliability of mappings between these together conspire to optimize learning" (237).

Chapter 9 Computational models of Language Usage, Acquisition, and Transmission
In the current chapter, language use, acquisition, and transmission of VACs were simulated in connectionist network models. First, simple recurrent networks (Elman 1990) were exposed to the native usage data from Chapter 8 to learn to predict the following word. In addition, the model was able to represent VACs in a semantic output layer. Results indicated that the model acquired VACs mainly based on verbs and some prepositions. For each VAC, the model predicts type-token distributions of verbs (and prepositions) resembling the distributions in learner usage. Remarkably, the model was also able to reliably predict the construction even when individual components were wugged (i.e., words were changed to 'wug', to simulate human learners ability to comprehend 'She wugged the napkin of the table.' as a caused-motion construction). "These simulations show how simple general learning mechanisms, exposed to the co-adapted language usage typical of NSs as they speak with NNSs, learn abstract VACs in the same order of emergence as NNSs and using the same cues" (254f.). In a subsequent simulation, the semantic layer was eliminated. The model still learns to group verbs in categories mirroring VACs, albeit somewhat slower than before. "Syntagmatic patterning alone is sufficient to allow the model to learn these different categories, albeit more slowly than when semantic information is also available" (257). In the following study, VAC usage and intergenerational transmission were simulated in agent-based models (Talking Heads paradigm). This is a way to investigate computationally the effects of different communication strategies in child-adult interactions upon effectiveness of communication, learnability across generations, emergence of conceptual structure, and Zipfian type-token usage distributions. In other words, the model simulates communicative interactions between adult and child. Adults were equipped with hierarchically structured conceptual knowledge. They were presented with a randomly generated scene of n objects and randomly chose an object to talk about and selected a name based on different communicative strategies (e.g., speaker least effort, i.e. select most general name; listener least effort, i.e. select most specific name; principle of least effort, i.e. choose level of naming which unambiguously differentiates the target object from the other items in the scene; etc.). The children would choose an object based on the name. Inititially, children know nothing of these names or of the conceptual structure, their memory is seeded by random activations. They then adjust their memory maps. Intergenerational transmission was modeled by removing adults, promoting children to adults, and introducing new children. Results indicated that when adults followed the principle of least effort, the propagated languages were most faithful to the original language, communicated the conceptual structure, and best fit Zipf's law in usage. "In Least Effort communication, the speaker takes both their and the listener's perspective into account, optimizing joint actions by minimizing both ambiguity and redundancy. So it is shared cooperative activity which gives language usage its shape" (277f.).

Chapter 10 VAC Usage, Processing, Acquisition, and Transmission
The current chapter summarizes the findings and draws some implications for future research and language pedagogy. The authors don't develop specific proposals but rather point to masses of other research related in content and method. All in all, they wish to draw the picture of language as a complex adaptive system which emerges from the dynamic interaction of multiscalar processes and elements. Moreover, limitations of the research presented in this monography are considered.},
  owner     = {daniel},
  timestamp = {2020.08.24},
}

@Book{Sinclair.1991,
  title     = {Corpus, concordance, collocation},
  publisher = {Oxford University Press},
  year      = {1991},
  author    = {Sinclair, John},
  address   = {Oxford, England},
  abstract  = {In chapter 5, Sinclair investigates meaning and use of various 'set *' phrasal verbs, e.g., 'set in', 'set off', 'set about', based on their collocations. He notes that phrasal verbs of the type in question have been known to be particularly problematic to acquire by (second language) learners and have been avoided by teachers presumably because of their vague and (as he comes to show) context-dependent meaning. He finds that "Each sense of the phrase is co-ordinated with a patterns of choice that helps to distinguish it from other sense. Each is particular; it has its uses and its characteristic environment" (78). 

In chapter 8, presumably the most important one in the book, Sinclair introduces the well-known and oft-cited idiom principle. In contrast to the predominant open-choice principle which envisages "texts as a series of slots which have to be filled from a lexicon which satisfies local restraints" and thus assumes "a very complete pattern of choices in progress at any moment" ("At each slot, virtually any word can occur.") (all quotes page 109), the idiom principles states that a language user's choices at any point are fundamentally restricted not only by real-world and register-related constraints but by language-specific constraints: "The principle of idiom is that a language user has available to him or her a large number of semi-preconstructed phrases that constitute single choices, even though they might appear to be analysable into segments" (110). He goes on to flesh out the principle which anticipates basic assumptions of Construction Grammar,e.g., gradual constituency/phrase boundaries, semi-fixed/-productive phrases, collocational and collostructional patterns, and domain-specific language use. He proposes that the idiom principle dominates most of language use, and that the open choice principle is only secondary. He illustrates his approach by describing the collocations of 'back'. He concludes that "All the evidence points to an underlying rigidity of phraseology, despite a rich superficial variation" (121).},
  owner     = {daniel},
  timestamp = {2020.08.24},
}

@Article{Wray.2000,
  author    = {Wray, Alison and Perkins, Michael R.},
  title     = {The functions of formulaic language: {A}n integrated model},
  journal   = {Language \& Communication},
  year      = {2000},
  volume    = {20},
  number    = {1},
  pages     = {1--28},
  abstract  = {In their influential article on formulaic language, Wray and Perkins review literature on the use and acquisition of formulaic language in various language user populations (first and second language learners, adults and children, aphasics) and propose an integrated model of processing, comprehension and acquisition of formulaic language. While they partially draw on usage-based research and mention construction grammar as a model of language which establishes formulaicity as a central principle, they focus on sequences of words and assume some analytical generative competence to account for creativity and novelty in language. They define formulaic sequence as ``a sequence, continuous or discontinuous, of words or other meaning elements, which is, or appears to be, prefabricated: that is, stored and retrieved whole from memory at the time of use, rather than being subject to generation or analysis by the language grammar'' (1). They point out the multi-faceted nature of formulaic language which ``is evident from the variety of ways in which it has been characterised: according to its form, function, semantic, syntactic and lexical properties, and its relationship with novel (analytic) language'' (3). A survey of earlier literature reveals a network of family resemblance relations between various types of formulaic language and between formulaic language and, e.g., metaphors. Formulaic language is often syntactically irregular and semantically opaque. Moreover, formulaic language displays various degress of cohesiveness and may be categorized along a continuum from novel to completely fixed sequences. While frequency has a role to play in formulaic language -- high frequency of exposure to particular forms and the frequent experience of recurrent contexts and situations of use contribute to the entrenchment of sequences --, the story behind formularization seems to be more complex involving social and developmental factors. The model Wray and Perkins propose ``is an attempt to account for the uses to which the individual puts formulaic language, and, specifically, what determines the choice, for that person, of a holistic or an analytic processing strategy at any given moment`` (11). Basically, the use and acquisition of formulaic language is proposed to be determined by two factors, namely, ``the priorities of social interaction and the constraints of memory on our processing capabilities'' (12). In their model, Wray and Perkins reconcile formulaic (holistic) with creative (analytic) language use and demonstrate the interdependency of social interaction and cognition. Formulaicity is seen as a tool for social interaction which is apparent from the fact that formulaic sequences often serve the language user's manipulation of her world and the expression of her individual and group identity, which involves the expression of sometimes complex social needs and purposes. This is seen as the evolutionary origin of human language which evolved from a protolanguage which ``had no words and no rules, just utterances associated with specific meanings, that achieved goals very similar to'' (14) the goals contemporary formulaic language achieves in social interaction among modern homo sapiens. Moreover, formulaicity is seen as a short-cut in processing to decrease the demand on working memory. Wray and Perkins argue that formulaic sequences ``represent an attempt to square an over-powerful analytic system that developed for reasons other than communication, with the inadequate working memory which is its forum'' (17). By by-passing the generative system, formulaic language decreases processing demands and ensures fluency of production and comprehension which is a prerequisite for social interaction -- and so the circle is complete. Last, Wray and Perkins attempt to explain why a analytic generative system develops at all. They argue that once children have acquired formulaic sequences early in life there is no need for children to engage in more complex and demanding social interaction but the redundant and repetitive interactions with their caregivers which is why they have time enough to use their developing cognitive powers to analyze and segment the formulaic sequences they memorized. From this, an analytical language system emerges. Once they enter into new, more complex and demanding social interactions, they begin to resort to formulaic language again to ease the processing demands. This model predicts the developmental curve observed in first language acquisition (Figure 4, page 20). Similar developments have been observed in second language acquisition. At first, it seems problematic to attribute the development from formulaic to analytical to formulaic language use to the cognitive and social development of second language learners because they potentially face all situations which grown-up native members of the respective language community face. However, Wray and Perkins argue that second language learners often escape from communicatively demanding social interactions and might therefore never accumulate the native repertoire of formulaic language.},
  doi       = {10.1016/S0271-5309(99)00015-4},
  owner     = {daniel},
  timestamp = {2020.08.24},
}

@Article{Johns.1991,
  author    = {Johns, Tim},
  title     = {Should you be persuaded: Two samples of data-driven learning materials},
  journal   = {Empirical Language Research},
  year      = {1991},
  volume    = {4},
  pages     = {1--16},
  abstract  = {In one of the earliest papers on data-driven language learning, Johns reports on experiences with two worksheets with concordances on English "convince vs. persuade" and the different uses of "should" in a Japanese English learners classroom. Against the background of the time, he dismisses computers as substitute teachers and instead conceives of them as some type of informant who if consulted in the right way would provide students with the linguistic data they need to work as researchers and discovers linguistic patterns of the target language themselves. The use of concordancers in the language classroom stimulates enquiry and speculation on the part of the learner and, in addition, changes the role of the teacher who becomes more of an director and coordinator of student-initiated research. Third, DDL reevaluates the place of grammar in language learning and lanuage teaching and makes possible "grammatical conscious-raising" (Rutherford 1987) "by placing the learner's own discovery of grammar at the centre of language learning, and by making it possible for that discovery to bt based on evidence from authentic language use" (page number unclear). Johns assumes that as side-effect learners arrive at generalisations more subtle and abstract than the ones that could be learned from and are usually introduced in textbooks. The basic pedagogical procedure: "identify - classify - generalise" (page number unclear) is illustrated with "convince vs persuade" and "should". Johns points out that negative evidence (lack of examples in the corpus concordances) is no valid basis for generalisations and, second, that normality (rather than correctness?) and relative frequency play an important role in inductive, corpus-based learning. Experience report on teaching "convince vs persuade" and different uses of "should" following.},
  owner     = {daniel},
  timestamp = {2020.08.25},
}

@InBook{Cobb.2015,
  pages     = {478--497},
  title     = {Classroom applications of corpus analysis},
  publisher = {Cambridge University Press},
  year      = {2015},
  author    = {Thomas Cobb and Alex Boulton},
  editor    = {Douglas Biber and Randi Reppen},
  address   = {Cambridge, England},
  abstract  = {Authors review empirical research on corpus-based learning / data-driven learning and report preliminary meta-analysis. The meta-analysis indicates that corpus-based learning is effective (in that corpus-based activities contribute to learning) and efficient (compared to other teaching approaches). Corpora are used by decision makes (e.g., language textbook maker) for the preparation of learning material which then later on influenes teaching, by teachers, and by students themselves inducing patterns from examples, comparing rules to actual usage, etc. The chapter and the meta-analysis are (mainly) on the last type of corpus use in language learner. In the conclusion, the authors formulate a series of open questions, e.g., are there different types of learners for whom corpus work is more or less suitable, what is the influence on motivation and long-term development of noticing, language awareness, etc. Aggregating over different forms of corpus usage in the language classroom, they write that "The basic idea is that massive but controlled exposure to authentic input is of major importance, as learners gradually respond to and reproduce the underlying lexical, grammatical, pragmatic, and other patterns implicit in the languages they encounter" (482).},
  booktitle = {The Cambridge Handbook of English Corpus Linguistics},
  owner     = {daniel},
